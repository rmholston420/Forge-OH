# Forge-OH — Required Environment Variables
# Copy to .env and fill in values before running locally.
# Never commit .env to source control.

# ----------------------------------------------------------------
# BFF (Backend For Frontend) — bff/.env
# ----------------------------------------------------------------

# Frontend origin for CORS. When set, credentialed requests are allowed
# from this exact origin. Leave blank in dev (wildcard, no credentials).
FRONTEND_ORIGIN=

# Ollama endpoint (default: local)
OLLAMA_URL=http://localhost:11434

# vLLM endpoint (default: local)
VLLM_URL=http://localhost:8001

# Ollama model names — must be pulled before running
# Never go below Q4_K_M quantization.
OLLAMA_PRIMARY_MODEL=devstral-small:24b
OLLAMA_FAST_MODEL=qwen3:14b

# vLLM fallback model — must match whatever model is loaded in vLLM.
# Previously defaulted to the literal string "vllm" which resolved
# to the nonsensical path "vllm/vllm".
VLLM_FALLBACK_MODEL=mistral:7b

# Redis — required for session/token state in multi-worker mode
REDIS_URL=redis://localhost:6379

# OpenHands sandbox configuration
OPENHANDS_WORKSPACE_DIR=/tmp/openhands-workspaces

# Secret key for JWT / token signing
SECRET_KEY=change-me-before-production

# ----------------------------------------------------------------
# Frontend (Next.js) — .env.local
# ----------------------------------------------------------------

# BFF base URL (used server-side in API route handlers)
BFF_URL=http://localhost:8000

# BFF WebSocket URL (used client-side for Socket.IO)
# NOTE: NEXT_PUBLIC_ prefix exposes this to the browser bundle.
# Route all API calls through src/app/api/* handlers to avoid
# leaking the BFF URL directly to the browser.
NEXT_PUBLIC_BFF_WS=ws://localhost:8000

# ----------------------------------------------------------------
# OpenHands SDK Agent Server
# ----------------------------------------------------------------
OPENHANDS_SDK_VERSION=1.29.3
OPENHANDS_AGENT_SERVER_HOST=localhost
OPENHANDS_AGENT_SERVER_PORT=8081
OPENHANDS_AGENT_SERVER_BASE_URL=http://localhost:8081
