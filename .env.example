# Forge-OH environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# BFF server
# Canonical port: 8081
# ---------------------------------------------------------------------------
BFF_PORT=8081
BFF_HOST=0.0.0.0
SECRET_KEY=change-me-in-production
TOKEN_TTL_HOURS=8
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# OpenHands SDK
# Canonical port: 8090
# SDK version: 1.29.3  |  Runtime image tag: 0.60.0
# ---------------------------------------------------------------------------
OPENHANDS_BASE_URL=http://localhost:8090
OPENHANDS_API_KEY=

# ---------------------------------------------------------------------------
# Frontend -> BFF (Next.js)
# Must match BFF_PORT above.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BFF_URL=http://localhost:8081

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
FEATURE_RIGPA_LMS_ENABLED=false

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
