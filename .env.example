# ============================================================
# Forge-OH Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- NextAuth (Required) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- GitHub OAuth (Optional) ---
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- BFF ---
NEXT_PUBLIC_BFF_URL=http://localhost:8000

# --- Rigpa-LMS Plugin Bridge (Optional) ---
# Base URL of your Rigpa-LMS instance
RIGPA_PLUGIN_URL=

# --- Feature Flags ---
# Set to 'true' to enable MSW mock service worker in browser
NEXT_PUBLIC_MSW_ENABLED=false
# Set to 'true' to seed BFF with demo data
DEMO_MODE=false

# --- Redis (Optional — for future session/queue store) ---
REDIS_URL=redis://localhost:6379
