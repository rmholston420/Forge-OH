# =============================================================================
# Forge-OH Environment Variables — copy to .env.local and fill in values
# =============================================================================

# --- BFF -------------------------------------------------------------------
# Base URL of the Forge BFF (Python FastAPI server)
NEXT_PUBLIC_BFF_BASE_URL=http://localhost:8080

# --- OpenHands (BFF-side only — never exposed to the frontend) -------------
OPENHANDS_BASE_URL=http://localhost:3000
OPENHANDS_API_KEY=

# --- Feature Flags (all default OFF) ----------------------------------------
# Enable each slice individually as it reaches Definition of Done.
# Value must be exactly "true" to enable.

# Phase 0
NEXT_PUBLIC_FEATURE_LIVE_STREAM=false

# Phase 1 — Run Command Centre
NEXT_PUBLIC_FEATURE_RUN_LIST=false
NEXT_PUBLIC_FEATURE_RUN_DETAIL_SHELL=false
NEXT_PUBLIC_FEATURE_PLAN_RAIL=false
NEXT_PUBLIC_FEATURE_EVENT_TIMELINE=false
NEXT_PUBLIC_FEATURE_APPROVAL_GATE=false

# Phase 2 — Artifact & Code Intelligence
NEXT_PUBLIC_FEATURE_ARTIFACT_VIEWER=false
NEXT_PUBLIC_FEATURE_TERMINAL_PANE=false
NEXT_PUBLIC_FEATURE_BROWSER_PANE=false
NEXT_PUBLIC_FEATURE_METRICS_PANE=false

# Phase 3 — Configuration Hub
NEXT_PUBLIC_FEATURE_WORKSPACE_MANAGER=false
NEXT_PUBLIC_FEATURE_AGENT_PRESETS=false
NEXT_PUBLIC_FEATURE_MCP_PANEL=false
NEXT_PUBLIC_FEATURE_SECRETS_VAULT=false

# Phase 4 — Observability Suite
NEXT_PUBLIC_FEATURE_OBSERVABILITY_OVERVIEW=false
NEXT_PUBLIC_FEATURE_LOOP_GUARD_MONITOR=false
NEXT_PUBLIC_FEATURE_TRACE_VIEWER=false

# Phase 5 — Plugin & Extension Layer
NEXT_PUBLIC_FEATURE_PLUGIN_MARKETPLACE=false
NEXT_PUBLIC_FEATURE_RUN_REPLAY=false
NEXT_PUBLIC_FEATURE_RIGPA_LMS=false       # gates src/lib/rbac/ (ADR 004)
